// Test program: Long RAW dependency chain
// Tests forwarding and hazard detection
//
// Program:
// MOV R1, #0x0001     @ 0x00: [00][09][01][00][01]
// ADD R2, R1          @ 0x05: [01][01][02][01]
// ADD R3, R2          @ 0x09: [01][01][03][02]
// ADD R4, R3          @ 0x0D: [01][01][04][03]
// ADD R5, R4          @ 0x11: [01][01][05][04]
// HLT                 @ 0x15: [00][12]
//
// Expected: R1=1, R2=1, R3=1, R4=1, R5=1
// (All use immediate mode, so no dependency)

00 09 01 00 01  // MOV R1, #1
01 01 02 01     // ADD R2, R1
01 01 03 02     // ADD R3, R2
01 01 04 03     // ADD R4, R3
01 01 05 04     // ADD R5, R4
00 12           // HLT
